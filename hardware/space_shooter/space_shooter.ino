int frame = 0;

void setup() {
  Serial.begin(115200);

  if(!display.begin(SSD1306_SWITCHCAPVCC, SCREEN_ADDRESS)) {
    Serial.println(F("Fallo I2C"));
    for(;;); 
  }
}

void loop() {
  display.clearDisplay();

  // Dibujar el fondo
  display.drawBitmap(0, 0, background_bmp, 128, 64, SSD1306_WHITE);

  // === Animaciones dinamicas superpuestas ===
  
  // 1. Rayos laser disparados por la nave (asumiendo que la nave esta a la derecha)
  // Calculamos la posicion X del laser
  int laser1X = 100 - ((frame * 4) % 120); 
  int laser2X = 80 - ((frame * 5) % 120);
  
  // Dibujamos lasers (lineas blancas sobre el fondo negro)
  // Usamos color BLACK e INVERSE para que se note en fondos mixtos, o simplemente blanco
  display.drawLine(laser1X, 28, laser1X - 6, 28, SSD1306_WHITE);
  display.drawLine(laser2X, 35, laser2X - 8, 35, SSD1306_WHITE);

  // 2. Estrellas moviendose rapidamente en paralaje (en el cielo, y=0 a y=20)
  for (int i = 0; i < 5; i++) {
    int starX = 128 - (((frame * (i+1)) / 2 + (i * 20)) % 128);
    int starY = 2 + (i * 4);
    // Borrar un puntito del fondo negro para que titile
    display.drawPixel(starX, starY, SSD1306_WHITE);
  }

  display.display();
  frame++;
  delay(30); // ~30 FPS
}
